#version 330 core
in vec2 TexCoord;
in vec3 FragPos;
in vec3 Normal;

out vec4 FragColor;

uniform sampler2D ringTexture;
uniform vec3 lightPos;
uniform vec3 viewPos;
uniform vec3 lightColor;
uniform float time;

// Simple 3D hash noise for granularity
float hash(vec3 p) {
    p  = fract(p * 0.3183099 + 0.1);
    p *= 17.0;
    return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
}

void main() {
    // Basic texture for overall density/color profile
    vec4 texColor = texture(ringTexture, vec2(TexCoord.x, 1.0 - TexCoord.y));
    if (texColor.a < 0.05) discard;

    vec3 norm = normalize(Normal);
    vec3 lightDir = normalize(lightPos - FragPos);
    vec3 viewDir = normalize(viewPos - FragPos);

    // Procedural granularity: simulate millions of ice chunks
    // Multiply FragPos by a high number to get a dense grid of noise
    float scale = 150.0;
    // Add time to make particles "twinkle" very slightly
    float noise = hash(floor(FragPos * scale) + vec3(time * 0.1));
    
    // Threshold noise to create discrete chunks, mixed back into the texture alpha
    float particleDensity = smoothstep(0.3, 0.7, noise);
    float finalAlpha = texColor.a * (0.4 + 0.6 * particleDensity);

    // Lighting
    float diff = max(dot(norm, lightDir), 0.0);
    float diffBack = max(dot(-norm, lightDir), 0.0);
    float finalDiff = max(diff, diffBack);

    // Mie Scattering (Forward Scattering for backlit dust/ice)
    float cosTheta = dot(viewDir, -lightDir);
    float g = 0.7; // Forward scattering bias
    float mieScattering = (1.0 - g*g) / pow(1.0 + g*g - 2.0*g*cosTheta, 1.5);
    mieScattering *= smoothstep(0.0, 1.0, cosTheta); // Blend based on view angle

    // Base color comes from texture + some noise variation to look like different ice chunks
    vec3 baseColor = texColor.rgb * (0.8 + 0.4 * noise);

    vec3 diffuse = finalDiff * lightColor * 0.8;
    vec3 ambient = 0.05 * lightColor;
    
    // Specular glint from ice
    vec3 halfDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(norm, halfDir), 0.0), 32.0);
    vec3 specular = spec * lightColor * particleDensity * 0.5;

    // Combine components
    vec3 scatterColor = lightColor * mieScattering * 0.3 * finalAlpha;
    vec3 result = (ambient + diffuse) * baseColor + specular + scatterColor;

    FragColor = vec4(result, finalAlpha);
}
